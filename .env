# TxLINE API Configuration
# See: https://txline.txodds.com/documentation/quickstart

# Network: 'devnet' or 'mainnet'
VITE_TXLINE_NETWORK=devnet

# Solana RPC URL (optional override — defaults are in config.ts)
# VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Pre-activated API token (Plano B: bypass on-chain auth)
# VITE_TXLINE_API_TOKEN=
# VITE_TXLINE_JWT=
